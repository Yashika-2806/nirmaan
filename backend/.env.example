# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/career-os?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# AI Keys (Initial Setup - More can be added via Admin Panel)
GEMINI_KEY_1=your-gemini-api-key-1
GEMINI_KEY_2=your-gemini-api-key-2
GEMINI_KEY_3=your-gemini-api-key-3

# Encryption Key for AI Keys in Database
ENCRYPTION_KEY=your-32-character-encryption-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@career-os.com
ADMIN_PASSWORD=change-this-password
